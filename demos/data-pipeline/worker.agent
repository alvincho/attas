{
  "name": "SQLiteADSWorker",
  "host": "127.0.0.1",
  "port": 9061,
  "party": "ADS",
  "type": "ads.agents.ADSWorkerAgent",
  "description": "Local SQLite-backed ADS worker for the public data-pipeline demo.",
  "pools": [
    {
      "type": "SQLitePool",
      "name": "ads_worker_pool",
      "description": "Shared SQLite ADS store for the live demo worker.",
      "db_path": "demos/data-pipeline/storage/ads_dispatcher.sqlite"
    }
  ],
  "ads": {
    "dispatcher_address": "http://127.0.0.1:9060",
    "capabilities": [
      "security_master",
      "daily_price",
      "fundamentals",
      "financial_statements",
      "news"
    ],
    "job_capabilities": [
      {
        "name": "security_master",
        "type": "ads.us_listed:USListedSecJobCap"
      },
      {
        "name": "daily_price",
        "type": "ads.yfinance:YFinanceEODJobCap"
      },
      {
        "name": "fundamentals",
        "type": "ads.examples.live_data_pipeline:LiveSECFundamentalsJobCap",
        "cache_dir": "demos/data-pipeline/storage/sec_edgar"
      },
      {
        "name": "financial_statements",
        "type": "ads.examples.live_data_pipeline:LiveSECFinancialStatementsJobCap",
        "cache_dir": "demos/data-pipeline/storage/sec_edgar"
      },
      {
        "name": "news",
        "type": "ads.rss_news:RSSNewsJobCap"
      }
    ],
    "poll_interval_sec": 0,
    "yfinance_request_cooldown_sec": 120,
    "auto_register": false
  }
}
