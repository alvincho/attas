{
  "name": "SQLiteADSWorker",
  "host": "127.0.0.1",
  "port": 9061,
  "party": "ADS",
  "type": "ads.agents.ADSWorkerAgent",
  "description": "Local SQLite-backed ADS worker for the public data-pipeline demo.",
  "pools": [
    {
      "type": "SQLitePool",
      "name": "ads_worker_pool",
      "description": "SQLite worker state for the demo.",
      "db_path": "demos/data-pipeline/storage/ads_worker.sqlite"
    }
  ],
  "ads": {
    "dispatcher_address": "http://127.0.0.1:9060",
    "capabilities": [
      "security_master",
      "daily_price",
      "fundamentals",
      "financial_statements",
      "news"
    ],
    "job_capabilities": [
      {
        "name": "security_master",
        "callable": "ads.examples.job_caps:mock_security_master_cap"
      },
      {
        "name": "daily_price",
        "callable": "ads.examples.job_caps:mock_daily_price_cap"
      },
      {
        "name": "fundamentals",
        "callable": "ads.examples.job_caps:mock_fundamentals_cap"
      },
      {
        "name": "financial_statements",
        "callable": "ads.examples.job_caps:mock_financial_statements_cap"
      },
      {
        "name": "news",
        "callable": "ads.examples.job_caps:mock_news_cap"
      }
    ],
    "poll_interval_sec": 2,
    "auto_register": false
  }
}
