      },
      {
        "name": "UPU WNS Listing",
        "description": "Fetch one UPU WNS stamp detail page and write the catalog item into the collectibles database."
      },
      {
        "name": "UPU WNS Item Image",
        "description": "Download one UPU WNS stamp image to local media storage and backfill the saved path into the database."
      }
    ],
