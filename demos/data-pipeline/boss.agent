{
  "name": "SQLiteADSBoss",
  "host": "127.0.0.1",
  "port": 9063,
  "party": "ADS",
  "type": "ads.boss.ADSBossAgent",
  "description": "Boss UI for the local SQLite-backed ADS public demo.",
  "pools": [
    {
      "type": "SQLitePool",
      "name": "ads_boss_pool",
      "description": "Boss UI local state for the demo.",
      "db_path": "demos/data-pipeline/storage/ads_boss.sqlite"
    }
  ],
  "ads": {
    "dispatcher_address": "http://127.0.0.1:9060",
    "job_capabilities": [
      {
        "name": "security_master",
        "description": "Refresh the full U.S. listed security master from Nasdaq Trader."
      },
      {
        "name": "daily_price",
        "description": "Fetch live Yahoo Finance end-of-day prices for the requested symbol.",
        "payload_template": {
          "symbol": "AAPL"
        }
      },
      {
        "name": "fundamentals",
        "description": "Refresh SEC raw archives and map the requested company into ads_fundamentals.",
        "payload_template": {
          "symbol": "AAPL"
        }
      },
      {
        "name": "financial_statements",
        "description": "Refresh SEC raw archives and map the requested company into ads_financial_statements.",
        "payload_template": {
          "symbol": "AAPL"
        }
      },
      {
        "name": "news",
        "description": "Fetch live SEC, CFTC, and BLS RSS feeds into ads_news.",
        "payload_template": {
          "feeds": [
            {
              "source": "SEC",
              "url": "https://www.sec.gov/news/pressreleases.rss"
            },
            {
              "source": "CFTC",
              "url": "https://www.cftc.gov/RSS/RSSGP/rssgp.xml"
            },
            {
              "source": "BLS",
              "url": "https://www.bls.gov/feed/bls_latest.rss"
            }
          ]
        },
        "parameters": [
          {
            "key": "feeds",
            "label": "RSS Feed URLs",
            "type": "feed_list",
            "help": "Add, remove, or edit the feeds this job should collect."
          }
        ]
      }
    ],
    "monitor_refresh_sec": 5,
    "auto_register": false
  }
}
