{
    "name": "AlphaVantageApiPulser",
    "type": "phemacast.pulsers.api_pulser.ApiPulser",
    "host": "127.0.0.1",
    "port": 8022,
    "plaza_url": "http://127.0.0.1:8011",
    "role": "pulser",
    "description": "Maps Alpha Vantage market, news, and fundamentals data onto shared Plaza pulse definitions.",
    "tags": [
        "finance",
        "market-data",
        "alpha-vantage",
        "stocks",
        "fundamentals",
        "news"
    ],
    "api_keys": [
        {
            "id": "alpha_vantage",
            "env": "ALPHA_VANTAGE_API_KEY",
            "param": "apikey"
        }
    ],
    "supported_pulses": [
        {
            "name": "last_price",
            "pulse_address": "2cc630e2-895f-5ced-a4df-6293a9c7b2d6",
            "description": "Latest traded price snapshot from GLOBAL_QUOTE.",
            "tags": [
                "stock-prices",
                "quote",
                "realtime"
            ],
            "api": {
                "url": "https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol={symbol}",
                "method": "GET",
                "api_key_id": "alpha_vantage"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "mapping": {
                "symbol": "Global Quote.01. symbol",
                "last_price": "Global Quote.05. price",
                "timestamp": "Global Quote.07. latest trading day",
                "source": {
                    "value": "alpha_vantage"
                }
            },
            "test_data": {
                "symbol": "IBM"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "previous_close",
