{
    "name": "YFinanceApiPulser",
    "type": "phemacast.pulsers.api_pulser.APIsPulser",
    "host": "127.0.0.1",
    "port": 8021,
    "plaza_url": "http://127.0.0.1:8011",
    "role": "pulser",
    "description": "Provides financial pulse data directly from Yahoo Finance APIs",
    "tags": [
        "finance",
        "yahoo",
        "market-data"
    ],
    "supported_pulses": [
        {
            "name": "last_price",
            "api": {
                "url": "https://query2.finance.yahoo.com/v8/finance/chart/{symbol}",
                "method": "GET",
                "root_path": "chart.result.0.meta"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "last_price": {
                        "type": "number"
                    }
                }
            },
            "mapping": {
                "symbol": "symbol",
                "last_price": "regularMarketPrice"
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "previous_close",
            "api": {
                "url": "https://query2.finance.yahoo.com/v8/finance/chart/{symbol}",
                "method": "GET",
                "root_path": "chart.result.0.meta"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "previous_close": {
                        "type": "number"
                    }
                }
            },
            "mapping": {
                "symbol": "symbol",
                "previous_close": "previousClose"
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "open_price",
            "api": {
                "url": "https://query2.finance.yahoo.com/v8/finance/chart/{symbol}",
                "method": "GET",
                "root_path": "chart.result.0.meta"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "open_price": {
                        "type": "number"
                    }
                }
            },
            "mapping": {
                "symbol": "symbol",
                "open_price": "regularMarketPrice"
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "market_state",
            "api": {
                "url": "https://query2.finance.yahoo.com/v8/finance/chart/{symbol}",
                "method": "GET",
                "root_path": "chart.result.0.meta"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "market_state": {
                        "type": "string"
                    }
                }
            },
            "mapping": {
                "symbol": "symbol",
                "market_state": "marketState"
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "day_high_low",
            "api": {
                "url": "https://query2.finance.yahoo.com/v8/finance/chart/{symbol}",
                "method": "GET",
                "root_path": "chart.result.0.meta"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "day_high": {
                        "type": "number"
                    },
                    "day_low": {
                        "type": "number"
                    }
                }
            },
            "mapping": {
                "symbol": "symbol",
                "day_high": "regularMarketDayHigh",
                "day_low": "regularMarketDayLow"
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "trade_volume",
            "api": {
                "url": "https://query2.finance.yahoo.com/v8/finance/chart/{symbol}",
                "method": "GET",
                "root_path": "chart.result.0.meta"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "volume": {
                        "type": "number"
                    },
                    "average_daily_volume_30d": {
                        "type": "number"
                    }
                }
            },
            "mapping": {
                "symbol": "symbol",
                "volume": "regularMarketVolume",
                "average_daily_volume_30d": "regularMarketVolume"
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        }
    ],
    "pools": [
        {
            "type": "FileSystemPool",
            "name": "yfinance_pool",
            "description": "YFinance local pool",
            "root_path": "tests/storage/yfinance"
        }
    ]
}
