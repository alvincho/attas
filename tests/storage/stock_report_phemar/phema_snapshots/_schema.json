{
  "name": "phema_snapshots",
  "description": "Persisted static Phema snapshots generated by a Phemar.",
  "primary_key": [
    "id"
  ],
  "rowSchema": {
    "id": {
      "type": "string"
    },
    "phema_id": {
      "type": "string"
    },
    "phema_name": {
      "type": "string"
    },
    "params_hash": {
      "type": "string"
    },
    "params": {
      "type": "json"
    },
    "tags": {
      "type": "json"
    },
    "snapshot": {
      "type": "json"
    },
    "cache_ttl_seconds": {
      "type": "integer"
    },
    "expires_at": {
      "type": "datetime"
    },
    "meta": {
      "type": "json"
    },
    "created_at": {
      "type": "datetime"
    },
    "updated_at": {
      "type": "datetime"
    }
  }
}