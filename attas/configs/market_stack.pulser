        {
            "name": "daily_ohlcv_bar",
            "pulse_address": "013ddac1-46e1-58b6-a2fc-7373c1d21ca0",
            "description": "Single dated EOD OHLCV bar from Marketstack.",
            "tags": [
                "historical-prices",
                "daily",
                "ohlcv"
            ],
            "api": {
                "url": "https://api.marketstack.com/v2/eod/{trade_date}?symbols={symbol}",
                "method": "GET",
                "root_path": "data.0",
                "api_key_id": "marketstack"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "trade_date": {
                        "type": "string",
                        "description": "EOD bar date in YYYY-MM-DD format."
                    }
                },
                "required": [
                    "symbol",
                    "trade_date"
                ]
            },
            "mapping": {
                "symbol": "symbol",
                "trade_date": "date",
                "open": "open",
                "high": "high",
                "low": "low",
                "close": "close",
                "adjusted_close": "adj_close",
                "volume": "volume",
                "source": {
                    "value": "marketstack"
                }
            },
            "test_data": {
                "symbol": "AAPL",
                "trade_date": "2024-09-27"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "intraday_ohlcv_bar",
            "pulse_address": "fed365ca-9ac2-5545-bb67-9568a39158c0",
            "description": "Latest intraday OHLCV bar from Marketstack for a given date and interval.",
            "tags": [
                "historical-prices",
                "intraday",
                "ohlcv"
            ],
            "api": {
                "url": "https://api.marketstack.com/v2/intraday/{trade_date}?symbols={symbol}&interval={interval}&limit=1&sort=DESC&after_hours={after_hours}",
                "method": "GET",
                "root_path": "data.0",
                "api_key_id": "marketstack"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "trade_date": {
                        "type": "string",
                        "description": "Intraday trade date in YYYY-MM-DD format."
                    },
                    "interval": {
                        "type": "string",
                        "enum": [
                            "1min",
                            "5min",
                            "10min",
                            "15min",
                            "30min",
                            "1hour",
                            "3hour",
                            "6hour",
                            "12hour",
                            "24hour"
                        ],
                        "default": "5min"
                    },
                    "after_hours": {
                        "type": "boolean",
                        "default": false
                    }
                },
                "required": [
                    "symbol",
                    "trade_date",
                    "interval"
                ]
            },
            "mapping": {
                "symbol": "symbol",
                "interval": "_input.interval",
                "bar_start": "date",
                "open": "open",
                "high": "high",
                "low": "low",
                "close": "marketstack_last",
                "volume": "volume",
                "source": {
                    "value": "marketstack"
                }
            },
            "test_data": {
                "symbol": "AAPL",
                "trade_date": "2024-09-27",
                "interval": "5min",
                "after_hours": false
            },
            "cost": 0,
            "party": "attas"
        },
        {
