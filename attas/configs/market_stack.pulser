{
    "name": "MarketstackApiPulser",
    "type": "phemacast.pulsers.api_pulser.APIsPulser",
    "host": "127.0.0.1",
    "port": 8024,
    "plaza_url": "http://127.0.0.1:8011",
    "role": "pulser",
    "description": "Maps Marketstack V2 end-of-day, intraday, dividend, split, and ticker data onto shared Plaza pulse definitions.",
    "tags": [
        "finance",
        "market-data",
        "marketstack",
        "stocks",
        "corporate-actions"
    ],
    "api_keys": [
        {
            "id": "marketstack",
            "env": "MARKETSTACK_API_KEY",
            "param": "access_key"
        }
    ],
    "supported_pulses": [
        {
            "name": "last_price",
            "pulse_address": "2cc630e2-895f-5ced-a4df-6293a9c7b2d6",
            "description": "Latest available end-of-day close from Marketstack.",
            "tags": [
                "stock-prices",
                "eod",
                "quote"
            ],
            "api": {
                "url": "https://api.marketstack.com/v2/eod/latest?symbols={symbol}",
                "method": "GET",
                "root_path": "data.0",
                "api_key_id": "marketstack"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "mapping": {
                "symbol": "symbol",
                "last_price": "close",
                "currency": "price_currency",
                "timestamp": "date",
                "exchange": "exchange",
                "source": {
                    "value": "marketstack"
                }
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "previous_close",
            "pulse_address": "e0ff71d7-e235-5027-9f74-94791fddf293",
            "description": "Previous official close from the second-most recent Marketstack EOD bar.",
            "tags": [
                "stock-prices",
                "eod",
                "quote"
            ],
            "api": {
                "url": "https://api.marketstack.com/v2/eod?symbols={symbol}&limit=2&sort=DESC",
                "method": "GET",
                "api_key_id": "marketstack"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    }
                },
                "required": [
                    "symbol"
                ]
            },
            "mapping": {
                "symbol": "data.1.symbol",
                "previous_close": "data.1.close",
                "trade_date": "data.1.date",
                "currency": "data.1.price_currency",
                "exchange": "data.1.exchange",
                "source": {
                    "value": "marketstack"
                }
            },
            "test_data": {
                "symbol": "AAPL"
            },
            "cost": 0,
            "party": "attas"
        },
        {
            "name": "open_price",
