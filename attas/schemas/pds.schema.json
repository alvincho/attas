{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://attas.ai/schemas/pds.schema.json",
  "title": "Pulse Definition Specification (PDS) v0.1.0",
  "description": "JSON Schema for PDS resources: pulse_definition, pulse_profile, pulse_mapping, and pulse_catalog.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/pulse_definition"
    },
    {
      "$ref": "#/$defs/pulse_profile"
    },
    {
      "$ref": "#/$defs/pulse_mapping"
    },
    {
      "$ref": "#/$defs/pulse_catalog"
    }
  ],
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "resource_id": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "schema_language": {
      "type": "string",
      "enum": [
        "json-schema-2020-12"
      ]
    },
    "pulse_class": {
      "type": "string",
      "enum": [
        "fact",
        "analytic",
        "artifact"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "stable",
        "deprecated"
      ]
    },
    "relation": {
      "type": "string",
      "enum": [
        "equivalent_match",
        "close_match",
        "broader_than",
        "narrower_than",
        "derived_from",
        "implements",
        "related"
      ]
    },
    "json_schema_object": {
      "type": "object"
    },
    "units": {
      "type": "object",
      "properties": {
        "value_type": {
          "type": "string"
        },
        "currency_required": {
          "type": "boolean"
        },
        "unit_required": {
          "type": "boolean"
        },
        "default_unit": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "time_semantics": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "point_in_time",
            "interval",
            "effective_dated",
            "announcement_dated",
            "filing_dated"
          ]
        },
        "timestamp_field": {
          "type": "string"
        },
        "modes": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": true
    },
    "external_ref": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "relation": {
          "$ref": "#/$defs/relation"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "system",
        "ref",
        "relation"
      ],
      "additionalProperties": true
    },
    "concept": {
      "type": "object",
      "properties": {
        "definition": {
          "type": "string",
          "minLength": 1
        },
        "entity_types": {
          "$ref": "#/$defs/string_array"
        },
        "tags": {
          "$ref": "#/$defs/string_array"
        },
        "dimensions": {
          "$ref": "#/$defs/string_array"
        },
        "identifiers": {
          "$ref": "#/$defs/string_array"
        },
        "units": {
          "$ref": "#/$defs/units"
        },
        "time_semantics": {
          "$ref": "#/$defs/time_semantics"
        },
        "quality_rules": {
          "$ref": "#/$defs/string_array"
        }
      },
      "required": [
        "definition"
      ],
      "additionalProperties": true
    },
    "interface": {
      "type": "object",
      "properties": {
        "schema_language": {
          "$ref": "#/$defs/schema_language"
        },
        "request_schema": {
          "$ref": "#/$defs/json_schema_object"
        },
        "response_schema": {
          "$ref": "#/$defs/json_schema_object"
        }
      },
      "required": [
        "schema_language",
        "request_schema",
        "response_schema"
      ],
      "additionalProperties": true
    },
    "interop": {
      "type": "object",
      "properties": {
        "aliases": {
          "$ref": "#/$defs/string_array"
        },
        "external_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_ref"
          }
        },
        "related_pulses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource_id"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "derivation": {
      "type": "object",
      "properties": {
        "input_pulse_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource_id"
          },
          "uniqueItems": true
        },
        "method_type": {
          "type": "string"
        },
        "method_ref": {
          "type": "string"
        },
        "parameters_schema": {
          "$ref": "#/$defs/json_schema_object"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object",
      "properties": {
        "owner": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        },
        "deprecated_by": {
          "$ref": "#/$defs/resource_id"
        },
        "change_notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "example_payloads": {
      "type": "array",
      "items": {}
    },
    "pulse_definition": {
      "type": "object",
      "properties": {
        "pds_version": {
          "const": "0.1.0"
        },
        "resource_type": {
          "const": "pulse_definition"
        },
        "id": {
          "$ref": "#/$defs/resource_id"
        },
        "namespace": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "pulse_class": {
          "$ref": "#/$defs/pulse_class"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "concept": {
          "$ref": "#/$defs/concept"
        },
        "interface": {
          "$ref": "#/$defs/interface"
        },
        "interop": {
          "$ref": "#/$defs/interop"
        },
        "derivation": {
          "$ref": "#/$defs/derivation"
        },
        "governance": {
          "$ref": "#/$defs/governance"
        },
        "examples": {
          "$ref": "#/$defs/example_payloads"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "required": [
        "pds_version",
        "resource_type",
        "id",
        "version",
        "title",
        "description",
        "pulse_class",
        "status",
        "concept",
        "interface"
      ],
      "additionalProperties": false
    },
    "pulse_profile": {
      "type": "object",
      "properties": {
        "pds_version": {
          "const": "0.1.0"
        },
        "resource_type": {
          "const": "pulse_profile"
        },
        "id": {
          "$ref": "#/$defs/resource_id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "base_pulse_id": {
          "$ref": "#/$defs/resource_id"
        },
        "application": {
          "type": "string"
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "defaults": {
          "type": "object",
          "additionalProperties": true
        },
        "presentation": {
          "type": "object",
          "additionalProperties": true
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "required": [
        "pds_version",
        "resource_type",
        "id",
        "version",
        "base_pulse_id"
      ],
      "additionalProperties": false
    },
    "pulse_mapping": {
      "type": "object",
      "properties": {
        "pds_version": {
          "const": "0.1.0"
        },
        "resource_type": {
          "const": "pulse_mapping"
        },
        "id": {
          "$ref": "#/$defs/resource_id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "pulse_id": {
          "$ref": "#/$defs/resource_id"
        },
        "source_system": {
          "type": "string"
        },
        "source_ref": {
          "type": "object",
          "additionalProperties": true
        },
        "relation": {
          "$ref": "#/$defs/relation"
        },
        "mapping_type": {
          "type": "string"
        },
        "field_map": {
          "type": "object",
          "additionalProperties": true
        },
        "transforms": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "coverage": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "notes": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "required": [
        "pds_version",
        "resource_type",
        "id",
        "version",
        "pulse_id",
        "source_system",
        "relation"
      ],
      "additionalProperties": false
    },
    "catalog_item": {
      "type": "object",
      "properties": {
        "ref": {
          "$ref": "#/$defs/resource_id"
        }
      },
      "required": [
        "ref"
      ],
      "additionalProperties": false
    },
    "pulse_catalog": {
      "type": "object",
      "properties": {
        "pds_version": {
          "const": "0.1.0"
        },
        "resource_type": {
          "const": "pulse_catalog"
        },
        "id": {
          "$ref": "#/$defs/resource_id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "imports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource_id"
          },
          "uniqueItems": true
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/catalog_item"
          },
          "minItems": 1
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "required": [
        "pds_version",
        "resource_type",
        "id",
        "version",
        "items"
      ],
      "additionalProperties": false
    }
  }
}