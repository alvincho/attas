        {
            "name": "intraday_ohlcv_bar",
            "pulse_address": "fed365ca-9ac2-5545-bb67-9568a39158c0",
            "description": "Single intraday OHLCV bar selected from TIME_SERIES_INTRADAY.",
            "tags": [
                "historical-prices",
                "intraday",
                "ohlcv"
            ],
            "api": {
                "url": "https://www.alphavantage.co/query?function=TIME_SERIES_INTRADAY&symbol={symbol}&interval={interval}&outputsize=compact&adjusted=true&extended_hours=false",
                "method": "GET",
                "root_path": "Time Series ({interval}).{bar_timestamp}",
                "api_key_id": "alpha_vantage"
            },
            "input_schema": {
                "type": "object",
                "properties": {
                    "symbol": {
                        "type": "string"
                    },
                    "interval": {
                        "type": "string",
                        "enum": [
                            "1min",
                            "5min",
                            "15min",
                            "30min",
                            "60min"
                        ],
                        "default": "5min"
                    },
                    "bar_timestamp": {
                        "type": "string",
                        "description": "Timestamp key present in the Alpha Vantage intraday series, for example 2026-03-18 16:00:00."
                    }
                },
                "required": [
                    "symbol",
                    "interval",
                    "bar_timestamp"
                ]
            },
            "mapping": {
                "symbol": "_input.symbol",
                "interval": "_input.interval",
                "bar_start": "_input.bar_timestamp",
                "open": "1. open",
                "high": "2. high",
                "low": "3. low",
                "close": "4. close",
                "volume": "5. volume",
                "source": {
                    "value": "alpha_vantage"
                }
            },
            "test_data": {
                "symbol": "IBM",
                "interval": "5min",
                "bar_timestamp": "2026-03-18 16:00:00"
            },
            "cost": 0,
            "party": "attas"
        },
