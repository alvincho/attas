{
  "name": "DemoOllamaPulser",
  "type": "attas.pulsers.openai_pulser.OpenAIPulser",
  "host": "127.0.0.1",
  "port": 8263,
  "plaza_url": "http://127.0.0.1:8261",
  "role": "pulser",
  "description": "Ollama-backed chat pulser for the standalone pulser demo set.",
  "tags": ["demo", "llm", "ollama", "chat", "local"],
  "pools": [
    {
      "type": "FileSystemPool",
      "name": "demo_ollama_pool",
      "description": "Local metadata pool for the Ollama pulser demo.",
      "root_path": "demos/pulsers/llm/storage/ollama"
    }
  ],
  "model": "qwen3:8b",
  "base_url": "http://localhost:11434/api/generate",
  "supported_pulses": [
    {
      "name": "llm_chat",
      "description": "Chat completion pulse via Ollama.",
      "tags": ["llm", "chat"],
      "input_schema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "model": {
            "type": "string"
          }
        },
        "required": ["prompt"]
      },
      "mapping": {
        "response": "response",
        "model": "model",
        "provider": "provider"
      },
      "test_data": {
        "prompt": "Say hello in one sentence.",
        "model": "qwen3:8b"
      },
      "party": "Demo"
    }
  ]
}
