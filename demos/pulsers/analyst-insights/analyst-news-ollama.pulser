          }
        },
        {
          "name": "normalize_output",
          "type": "python",
          "script_path": "./analyst_news_ollama_step.py"
        }
      ],
      "result_path": "steps.normalize_output",
      "input_schema": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "number_of_articles": {
            "type": "integer"
          },
          "model": {
            "type": "string"
          }
        },
        "required": [
          "symbol"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "analyst": {
            "type": "string"
          },
          "prompt_profile": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "source_articles": {
            "type": "integer"
          },
          "updated_at": {
            "type": "string"
          },
          "changed_view": {
            "type": "string"
          },
          "monitor_now": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "citations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "symbol",
          "analyst",
          "prompt_profile",
          "changed_view",
          "monitor_now",
          "risk_flags",
          "citations"
        ]
      },
      "test_data": {
        "symbol": "NVDA",
        "number_of_articles": 2,
        "model": "qwen3:8b"
      }
    },
    {
      "name": "news_client_note",
      "pulse_address": "plaza://pulse/demo_analyst_news_client_note",
      "description": "Client-safe note generated from another agent's raw news feed.",
      "tags": [
        "analyst",
        "news",
        "client"
      ],
      "prompt_profile": "client_note",
      "default_model": "qwen3:8b",
      "steps": [
        {
          "name": "fetch_news",
          "type": "source",
          "pulser_url": "http://127.0.0.1:8268",
          "pulse_name": "news_article",
          "params": {
            "symbol": "{{_input.symbol}}",
            "number_of_articles": "{{_input.number_of_articles}}"
          }
        },
        {
          "name": "build_prompt",
          "type": "python",
          "script_path": "./analyst_news_ollama_step.py"
        },
        {
          "name": "llm_analysis",
          "type": "source",
          "pulser_url": "http://127.0.0.1:8269",
          "pulse_name": "llm_chat",
          "params": {
            "prompt": "{{_previous.prompt}}",
            "model": "{{_previous.model}}"
          }
        },
        {
          "name": "normalize_output",
          "type": "python",
          "script_path": "./analyst_news_ollama_step.py"
        }
      ],
      "result_path": "steps.normalize_output",
      "input_schema": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "number_of_articles": {
            "type": "integer"
          },
          "model": {
            "type": "string"
          }
        },
        "required": [
          "symbol"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "analyst": {
            "type": "string"
          },
          "prompt_profile": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "source_articles": {
            "type": "integer"
          },
          "updated_at": {
            "type": "string"
          },
          "subject_line": {
            "type": "string"
          },
          "client_note": {
            "type": "string"
          },
          "action_items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "citations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "symbol",
          "analyst",
          "prompt_profile",
          "subject_line",
          "client_note",
          "action_items",
          "citations"
        ]
      },
      "test_data": {
        "symbol": "NVDA",
        "number_of_articles": 2,
        "model": "qwen3:8b"
      }
    }
  ]
}
