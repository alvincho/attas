{
  "name": "SQLiteADSBoss",
  "host": "127.0.0.1",
  "port": 9063,
  "party": "ADS",
  "type": "ads.boss.ADSBossAgent",
  "description": "Boss UI for the local SQLite-backed ADS public demo.",
  "pools": [
    {
      "type": "SQLitePool",
      "name": "ads_boss_pool",
      "description": "Boss UI local state for the demo.",
      "db_path": "demos/data-pipeline/storage/ads_boss.sqlite"
    }
  ],
  "ads": {
    "dispatcher_address": "http://127.0.0.1:9060",
    "job_capabilities": [
      {
        "name": "security_master",
        "description": "Create a demo security master row.",
        "payload_template": {
          "symbol": "AAPL"
        }
      },
      {
        "name": "daily_price",
        "description": "Create a demo daily price row.",
        "payload_template": {
          "symbol": "AAPL"
        }
      },
      {
        "name": "fundamentals",
        "description": "Create a demo fundamentals row.",
        "payload_template": {
          "symbol": "AAPL"
        }
      },
      {
        "name": "financial_statements",
        "description": "Create a demo financial statement row.",
        "payload_template": {
          "symbol": "AAPL",
          "statement_type": "income_statement"
        }
      },
      {
        "name": "news",
        "description": "Create a demo news row.",
        "payload_template": {
          "symbol": "AAPL"
        }
      }
    ],
    "monitor_refresh_sec": 5,
    "auto_register": false
  }
}
