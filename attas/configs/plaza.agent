{
    "name": "plaza",
    "role": "coordinator",
    "tags": ["mediator"],
    "host": "127.0.0.1",
    "port": 8011,
    "pools": [
        {
            "type": "SupabasePool",
            "name": "plaza_pool",
            "description": "Plaza Supabase pool",
            "url": {
                "env": "SUPABASE_URL"
            },
            "key": {
                "env": "SUPABASE_SERVICE_ROLE_KEY"
            }
        }
    ],
    "type": "prompits.core.plaza.PlazaAgent",
    "plaza": {
        "init_files":[
            "attas/init_pits"
        ]
    },
    "practices": [
        {
            "type": "prompits.practices.plaza.PlazaPractice",
            "params": {}
        }
    ]
}
