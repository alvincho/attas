{
  "name": "ADSBoss",
  "host": "127.0.0.1",
  "port": 8063,
  "party": "ADS",
  "type": "ads.boss.ADSBossAgent",
  "description": "Operator UI for issuing ADS jobs to the dispatcher.",
  "pools": [
    {
      "type": "PostgresPool",
      "name": "ads_boss_pool",
      "description": "Shared ADS PostgreSQL boss state",
      "schema": {
        "env": "ADS_POSTGRES_SCHEMA",
        "fallback": "public"
      },
      "sslmode": {
        "env": "ADS_POSTGRES_SSLMODE",
        "fallback": "disable"
      }
    }
  ],
  "ads": {
    "dispatcher_address": "http://127.0.0.1:8060",
    "worker_config_path": "worker.agent",
    "job_capabilities": [
      {
        "name": "Daily Job Archive",
        "description": "Sweep completed ADS jobs out of the active queue into ads_jobs_archive."
      },
      {
        "name": "US Listed Sec to security master",
        "description": "Refresh the U.S. listed security master from Nasdaq Trader symbol directories."
      },
      {
        "name": "US Filing Bulk",
        "description": "Download SEC EDGAR companyfacts.zip and submissions.zip into raw ADS SEC tables."
      },
      {
        "name": "US Filing Mapping",
        "description": "Map one company's SEC companyfacts and submissions rows into ADS fundamentals and financial statements.",
        "payload_template": {
          "cik": "0000320193"
        }
      },
      {
        "name": "YFinance EOD",
        "description": "Fetch Yahoo Finance end-of-day prices."
      },
      {
        "name": "YFinance US Market EOD",
        "description": "Queue per-symbol Yahoo Finance end-of-day jobs for active USD securities oldest-first."
      },
      {
        "name": "TWSE Market EOD",
        "description": "Fetch Taiwan Stock Exchange market-wide end-of-day prices."
      },
      {
        "name": "RSS News",
        "description": "Fetch SEC, CFTC, and BLS RSS feeds into ads_news with editable feed URLs.",
        "payload_template": {
          "feeds": [
            {
              "source": "SEC",
              "url": "https://www.sec.gov/news/pressreleases.rss"
            },
            {
              "source": "CFTC",
              "url": "https://www.cftc.gov/RSS/RSSGP/rssgp.xml"
            },
            {
              "source": "BLS",
              "url": "https://www.bls.gov/feed/bls_latest.rss"
            }
          ]
        },
        "parameters": [
          {
            "key": "feeds",
            "label": "RSS Feed URLs",
            "type": "feed_list",
            "help": "Add, remove, or edit the feeds this job should collect."
          }
        ]
      }
    ],
    "scheduled_jobs": [
      {
        "id": "ads-boss-schedule:daily-job-archive",
        "name": "Daily Job Archive (3AM)",
        "required_capability": "Daily Job Archive",
        "repeat_frequency": "daily",
        "schedule_timezone": "Asia/Shanghai",
        "schedule_times": ["03:00"],
        "priority": 80,
        "payload": {
          "batch_size": 1000
        }
      }
    ],
    "auto_register": false
  }
}
